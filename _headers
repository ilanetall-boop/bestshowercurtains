# Headers for best-shower-curtains.com
# Cloudflare Pages _headers file

# Security headers for all pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Cache static assets (1 week, revalidate)
/images/*
  Cache-Control: public, max-age=604800, must-revalidate

/*.css
  Cache-Control: public, max-age=604800, must-revalidate

/*.js
  Cache-Control: public, max-age=604800, must-revalidate

# Cache HTML pages for 10 minutes (allows for quick updates)
/*.html
  Cache-Control: public, max-age=600, must-revalidate

# JSON data files - no cache (articles.json changes frequently)
/*.json
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap and robots - short cache
/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400
